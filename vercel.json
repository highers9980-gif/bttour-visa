{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://designs-explicit-mia-pharmacology.trycloudflare.com/api/:path*" },
    { "source": "/download/:path*", "destination": "https://designs-explicit-mia-pharmacology.trycloudflare.com/download/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
